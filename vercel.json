{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://healthos-production.up.railway.app/api/$1" },
    { "source": "/admin/(.*)", "destination": "https://healthos-production.up.railway.app/admin/$1" },
    { "source": "/chat/(.*)", "destination": "https://healthos-production.up.railway.app/chat/$1" },
    { "source": "/((?!api|admin|chat).*)", "destination": "/index.html" }
  ]
}
