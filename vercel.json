{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/admin/(.*)", "destination": "/api/index.ts" },
    { "source": "/chat/(.*)", "destination": "/api/index.ts" },
    { "source": "/((?!api|admin|chat).*)", "destination": "/index.html" }
  ]
}
